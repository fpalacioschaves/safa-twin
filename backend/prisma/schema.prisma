generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ProgrammeType {
  BASIC
  INTERMEDIATE
  HIGHER
  SPECIALIZATION
}

enum StudyModality {
  PRESENTIAL
  ONLINE
  BLENDED
}

enum StudentDocumentType {
  DNI
  NIE
  PASSPORT
  OTHER
}

enum EnrolmentStatus {
  ENROLLED
  WITHDRAWN
  CONVALIDATED
  EXEMPT
  PENDING
  COMPLETED
}

enum EvaluationStatus {
  DRAFT
  OPEN
  CLOSED
  LOCKED
}

enum AssessmentComponentType {
  ACTIVITIES
  SELF_ASSESSMENTS
  FORUMS
  COMPANY
  OTHER
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(150)
  email        String    @unique @db.VarChar(191)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(0)

  userRoles UserRole[]
  sessions  Session[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(150)
  slug        String   @unique @db.VarChar(150)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.DateTime(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.DateTime(0)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Session {
  tokenHash  String   @id @map("token_hash") @db.Char(64)
  userId     Int      @map("user_id")
  expiresAt  DateTime @map("expires_at") @db.DateTime(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(0)
  lastUsedAt DateTime @default(now()) @map("last_used_at") @db.DateTime(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AcademicYear {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(20)
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime  @map("end_date") @db.Date
  isCurrent Boolean   @default(false) @map("is_current")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  academicOfferings AcademicOffering[]
  enrolments         Enrolment[]
  evaluations        Evaluation[]
  assessmentSchemes  AssessmentScheme[]

  @@index([isCurrent])
  @@index([isActive])
  @@index([deletedAt])
  @@map("academic_years")
}

model Centre {
  id         Int       @id @default(autoincrement())
  code       String    @unique @db.VarChar(50)
  name       String    @db.VarChar(191)
  shortName  String?   @map("short_name") @db.VarChar(100)
  taxId      String?   @map("tax_id") @db.VarChar(20)
  address    String?   @db.VarChar(255)
  postalCode String?   @map("postal_code") @db.VarChar(10)
  city       String?   @db.VarChar(100)
  province   String?   @db.VarChar(100)
  phone      String?   @db.VarChar(30)
  email      String?   @db.VarChar(191)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt  DateTime? @map("deleted_at") @db.DateTime(0)

  centreProgrammes  CentreProgramme[]
  enrolments        Enrolment[]
  evaluations       Evaluation[]
  assessmentSchemes AssessmentScheme[]

  @@index([name])
  @@index([city])
  @@index([province])
  @@index([isActive])
  @@index([deletedAt])
  @@map("centres")
}

model VocationalProgramme {
  id          Int           @id @default(autoincrement())
  code        String        @unique @db.VarChar(50)
  name        String        @db.VarChar(191)
  acronym     String        @unique @db.VarChar(20)
  family      String?       @db.VarChar(150)
  type        ProgrammeType @default(HIGHER)
  totalHours  Int?          @map("total_hours")
  description String?       @db.Text
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt   DateTime?     @map("deleted_at") @db.DateTime(0)

  centreProgrammes CentreProgramme[]
  modules          Module[]

  @@index([name])
  @@index([family])
  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("vocational_programmes")
}

model CentreProgramme {
  centreId              Int       @map("centre_id")
  vocationalProgrammeId Int       @map("vocational_programme_id")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt             DateTime? @map("deleted_at") @db.DateTime(0)

  centre              Centre              @relation(fields: [centreId], references: [id], onDelete: Restrict)
  vocationalProgramme VocationalProgramme @relation(fields: [vocationalProgrammeId], references: [id], onDelete: Restrict)
  academicOfferings   AcademicOffering[]

  @@id([centreId, vocationalProgrammeId])
  @@index([vocationalProgrammeId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("centre_programmes")
}

model AcademicLevel {
  id          Int       @id @default(autoincrement())
  number      Int       @unique
  name        String    @unique @db.VarChar(50)
  description String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(0)

  academicOfferings AcademicOffering[]
  modules           Module[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("academic_levels")
}

model AcademicOffering {
  id                    Int           @id @default(autoincrement())
  academicYearId        Int           @map("academic_year_id")
  centreId              Int           @map("centre_id")
  vocationalProgrammeId Int           @map("vocational_programme_id")
  academicLevelId       Int           @map("academic_level_id")
  modality              StudyModality
  isActive              Boolean       @default(true) @map("is_active")
  createdAt             DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt             DateTime?     @map("deleted_at") @db.DateTime(0)

  academicYear    AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  centreProgramme CentreProgramme @relation(fields: [centreId, vocationalProgrammeId], references: [centreId, vocationalProgrammeId], onDelete: Restrict)
  academicLevel   AcademicLevel   @relation(fields: [academicLevelId], references: [id], onDelete: Restrict)

  @@unique([academicYearId, centreId, vocationalProgrammeId, academicLevelId, modality], map: "academic_offerings_scope_unique")
  @@index([academicYearId])
  @@index([centreId, vocationalProgrammeId])
  @@index([academicLevelId])
  @@index([modality])
  @@index([isActive])
  @@index([deletedAt])
  @@map("academic_offerings")
}

model Module {
  id                    Int       @id @default(autoincrement())
  vocationalProgrammeId Int       @map("vocational_programme_id")
  academicLevelId       Int       @map("academic_level_id")
  code                  String    @db.VarChar(50)
  name                  String    @db.VarChar(191)
  acronym               String?   @db.VarChar(30)
  totalHours            Int?      @map("total_hours")
  weeklyHours           Decimal?  @map("weekly_hours") @db.Decimal(4, 2)
  sortOrder             Int       @default(0) @map("sort_order")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt             DateTime? @map("deleted_at") @db.DateTime(0)

  vocationalProgramme VocationalProgramme @relation(fields: [vocationalProgrammeId], references: [id], onDelete: Restrict)
  academicLevel       AcademicLevel       @relation(fields: [academicLevelId], references: [id], onDelete: Restrict)
  enrolments          Enrolment[]
  assessmentSchemes   AssessmentScheme[]

  @@unique([vocationalProgrammeId, code], map: "modules_programme_code_unique")
  @@index([vocationalProgrammeId])
  @@index([academicLevelId])
  @@index([name])
  @@index([sortOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("modules")
}

model Student {
  id                    Int                  @id @default(autoincrement())
  studentCode           String?              @unique @map("student_code") @db.VarChar(50)
  firstName             String               @map("first_name") @db.VarChar(100)
  lastName1             String               @map("last_name_1") @db.VarChar(100)
  lastName2             String?              @map("last_name_2") @db.VarChar(100)
  documentType          StudentDocumentType? @map("document_type")
  documentNumber        String?              @unique @map("document_number") @db.VarChar(30)
  email                 String?              @db.VarChar(191)
  phone                 String?              @db.VarChar(30)
  birthDate             DateTime?            @map("birth_date") @db.Date
  address               String?              @db.VarChar(255)
  postalCode            String?              @map("postal_code") @db.VarChar(10)
  city                  String?              @db.VarChar(100)
  province              String?              @db.VarChar(100)
  emergencyContactName  String?              @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactPhone String?              @map("emergency_contact_phone") @db.VarChar(30)
  notes                 String?              @db.Text
  isActive              Boolean              @default(true) @map("is_active")
  createdAt             DateTime             @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt             DateTime?            @map("deleted_at") @db.DateTime(0)

  enrolments            Enrolment[]

  @@index([firstName])
  @@index([lastName1, lastName2])
  @@index([email])
  @@index([city])
  @@index([province])
  @@index([isActive])
  @@index([deletedAt])
  @@map("students")
}

model Enrolment {
  id             Int             @id @default(autoincrement())
  studentId      Int             @map("student_id")
  academicYearId Int             @map("academic_year_id")
  centreId       Int             @map("centre_id")
  moduleId       Int             @map("module_id")
  status         EnrolmentStatus @default(ENROLLED)
  enrolledAt     DateTime        @map("enrolled_at") @db.Date
  cancelledAt    DateTime?       @map("cancelled_at") @db.Date
  remarks        String?         @db.Text
  createdAt      DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt      DateTime?       @map("deleted_at") @db.DateTime(0)

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  centre       Centre       @relation(fields: [centreId], references: [id], onDelete: Restrict)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  grades       Grade[]

  @@unique([studentId, academicYearId, centreId, moduleId], map: "enrolments_student_year_centre_module_unique")
  @@index([studentId])
  @@index([academicYearId])
  @@index([centreId])
  @@index([moduleId])
  @@index([status])
  @@index([enrolledAt])
  @@index([deletedAt])
  @@map("enrolments")
}


model Evaluation {
  id             Int              @id @default(autoincrement())
  academicYearId Int              @map("academic_year_id")
  centreId       Int              @map("centre_id")
  code           String           @db.VarChar(50)
  name           String           @db.VarChar(150)
  sequence       Int              @default(0)
  startsAt       DateTime?        @map("starts_at") @db.Date
  endsAt         DateTime?        @map("ends_at") @db.Date
  status         EvaluationStatus @default(DRAFT)
  closedAt       DateTime?        @map("closed_at") @db.DateTime(0)
  remarks        String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt      DateTime?        @map("deleted_at") @db.DateTime(0)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  centre       Centre       @relation(fields: [centreId], references: [id], onDelete: Restrict)
  grades       Grade[]

  @@unique([academicYearId, centreId, code], map: "evaluations_scope_code_unique")
  @@index([academicYearId])
  @@index([centreId])
  @@index([status])
  @@index([sequence])
  @@index([startsAt])
  @@index([endsAt])
  @@index([deletedAt])
  @@map("evaluations")
}

model GradeStatus {
  id              Int       @id @default(autoincrement())
  code            String    @unique @db.VarChar(30)
  name            String    @db.VarChar(100)
  description     String?   @db.VarChar(255)
  isEvaluable     Boolean   @default(false) @map("is_evaluable")
  countsAsPassed  Boolean   @default(false) @map("counts_as_passed")
  countsAsNoShow  Boolean   @default(false) @map("counts_as_no_show")
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt       DateTime? @map("deleted_at") @db.DateTime(0)

  grades          Grade[]

  @@index([sortOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("grade_statuses")
}

model AssessmentScheme {
  id             Int       @id @default(autoincrement())
  academicYearId Int      @map("academic_year_id")
  centreId       Int      @map("centre_id")
  moduleId       Int      @map("module_id")
  name           String   @db.VarChar(150)
  isDual         Boolean  @default(false) @map("is_dual")
  isActive       Boolean  @default(true) @map("is_active")
  remarks        String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt      DateTime? @map("deleted_at") @db.DateTime(0)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  centre       Centre       @relation(fields: [centreId], references: [id], onDelete: Restrict)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  components   AssessmentComponent[]
  grades       Grade[]

  @@unique([academicYearId, centreId, moduleId], map: "assessment_schemes_scope_unique")
  @@index([academicYearId])
  @@index([centreId])
  @@index([moduleId])
  @@index([isDual])
  @@index([isActive])
  @@index([deletedAt])
  @@map("assessment_schemes")
}

model AssessmentComponent {
  id                 Int                     @id @default(autoincrement())
  assessmentSchemeId Int                     @map("assessment_scheme_id")
  code               String                  @db.VarChar(50)
  name               String                  @db.VarChar(150)
  type               AssessmentComponentType @default(OTHER)
  percentage         Decimal                 @db.Decimal(5, 2)
  sortOrder          Int                     @default(0) @map("sort_order")
  isRequired         Boolean                 @default(true) @map("is_required")
  isCompanyComponent Boolean                 @default(false) @map("is_company_component")
  createdAt          DateTime                @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.DateTime(0)

  assessmentScheme AssessmentScheme @relation(fields: [assessmentSchemeId], references: [id], onDelete: Cascade)
  componentScores   GradeComponentScore[]

  @@unique([assessmentSchemeId, code], map: "assessment_components_scheme_code_unique")
  @@index([assessmentSchemeId])
  @@index([type])
  @@index([sortOrder])
  @@map("assessment_components")
}


model Grade {
  id                 Int       @id @default(autoincrement())
  enrolmentId        Int       @map("enrolment_id")
  evaluationId       Int       @map("evaluation_id")
  assessmentSchemeId Int       @map("assessment_scheme_id")
  gradeStatusId      Int?      @map("grade_status_id")
  numericGrade       Decimal?  @map("numeric_grade") @db.Decimal(4, 2)
  finalGrade         Decimal?  @map("final_grade") @db.Decimal(4, 2)
  isPassed           Boolean?  @map("is_passed")
  isLocked           Boolean   @default(false) @map("is_locked")
  remarks            String?   @db.Text
  createdAt          DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt          DateTime? @map("deleted_at") @db.DateTime(0)

  enrolment        Enrolment         @relation(fields: [enrolmentId], references: [id], onDelete: Restrict)
  evaluation       Evaluation        @relation(fields: [evaluationId], references: [id], onDelete: Restrict)
  assessmentScheme AssessmentScheme  @relation(fields: [assessmentSchemeId], references: [id], onDelete: Restrict)
  gradeStatus      GradeStatus?      @relation(fields: [gradeStatusId], references: [id], onDelete: Restrict)
  componentScores  GradeComponentScore[]

  @@unique([enrolmentId, evaluationId], map: "grades_enrolment_evaluation_unique")
  @@index([enrolmentId])
  @@index([evaluationId])
  @@index([assessmentSchemeId])
  @@index([gradeStatusId])
  @@index([finalGrade])
  @@index([isPassed])
  @@index([isLocked])
  @@index([deletedAt])
  @@map("grades")
}

model GradeComponentScore {
  id                    Int       @id @default(autoincrement())
  gradeId               Int       @map("grade_id")
  assessmentComponentId Int       @map("assessment_component_id")
  score                 Decimal?  @db.Decimal(4, 2)
  weightedScore         Decimal?  @map("weighted_score") @db.Decimal(5, 2)
  isMissing             Boolean   @default(false) @map("is_missing")
  remarks               String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  grade               Grade               @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  assessmentComponent AssessmentComponent @relation(fields: [assessmentComponentId], references: [id], onDelete: Restrict)

  @@unique([gradeId, assessmentComponentId], map: "grade_component_scores_unique")
  @@index([gradeId])
  @@index([assessmentComponentId])
  @@index([isMissing])
  @@map("grade_component_scores")
}
